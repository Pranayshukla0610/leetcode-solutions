      "source": [
        "#Reverse String\n",
        "\n",
        "class Solution:\n",
        "  def reversestring(str,s):\n",
        "    l = 0\n",
        "    r = len(s)-1\n",
        "\n",
        "    while l < r:\n",
        "      s[l], s[r] = s[r], s[l]\n",
        "      l += 1\n",
        "      r -= 1"
      ]
    },
