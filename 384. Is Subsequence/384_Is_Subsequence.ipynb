      "source": [
        "#IS SUBSEQUENCE\n",
        "\n",
        "class Solution:\n",
        "  def issubsequence(s,t):\n",
        "    i = 0\n",
        "    j = 0\n",
        "    while i < len(s) and j < len(t):\n",
        "      if s[i] == t[j]:\n",
        "        i += 1\n",
        "      j += 1\n",
        "    return i == len(s)"
      ]
    },
